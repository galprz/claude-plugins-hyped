{
  "manifest_version": 3,
  "name": "Hyped Chrome Tool",
  "version": "1.0.0",
  "description": "Browser automation for Hyped agents",
  "permissions": ["debugger", "tabs", "storage", "offscreen", "tabCapture"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Hyped Chrome Tool",
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    { "resources": ["offscreen-handoff.html"], "matches": ["<all_urls>"] }
  ]
}
