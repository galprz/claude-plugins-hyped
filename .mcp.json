{
  "mcpServers": {
    "hyped-cron": {
      "command": "bun",
      "args": [
        "run",
        "--cwd",
        "${CLAUDE_PLUGIN_ROOT}/mcp/hyped-cron",
        "--silent",
        "start"
      ]
    },
    "local-tts": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}/mcp/local-tts",
        "local-tts-mcp"
      ]
    },
    "local-tunnel": {
      "command": "bun",
      "args": [
        "run",
        "--cwd",
        "${CLAUDE_PLUGIN_ROOT}/mcp/local-tunnel",
        "--silent",
        "start"
      ]
    }
  }
}
